APP_ENV=development
DEBUG=false
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/reporting
SYNC_DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/reporting
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
TASK_ALWAYS_EAGER=false
JWT_SECRET_KEY=change-this-secret
JWT_AUDIENCE=reporting-api
JWT_ISSUER=reporting-service
DOWNLOAD_TOKEN_SECRET=change-this-download-secret
DOWNLOAD_TOKEN_TTL_SECONDS=900
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage/private
LOG_LEVEL=INFO
